# DASHSCOPE_API_KEY / QWEN_API_KEY: use one Qwen-compatible key.
# The server talks to the official Qwen OpenAI-compatible endpoint.
DASHSCOPE_API_KEY="MY_QWEN_API_KEY"
QWEN_TEXT_MODEL="qwen-plus"

# Optional: local TTS endpoint. Leave unset to keep only Qwen active.
# EDGE_TTS_BASE_URL="http://localhost:5050"
# EDGE_TTS_API_KEY="MY_EDGE_TTS_API_KEY"
# EDGE_TTS_DEFAULT_VOICE="uk-UA-PolinaNeural"
# EDGE_TTS_DEFAULT_FORMAT="mp3"

# APP_URL: public app URL when deployed.
APP_URL="MY_APP_URL"
