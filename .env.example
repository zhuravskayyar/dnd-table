# NVIDIA API key for text generation.
# Get one at https://build.nvidia.com
NVIDIA_API_KEY="nvapi-..."
NVIDIA_TEXT_MODEL="nvidia/llama-3.3-nemotron-super-49b-v1"

# Optional: local TTS endpoint. Leave unset to keep only NVIDIA active.
# EDGE_TTS_BASE_URL="http://localhost:5050"
# EDGE_TTS_API_KEY="MY_EDGE_TTS_API_KEY"
# EDGE_TTS_DEFAULT_VOICE="uk-UA-PolinaNeural"
# EDGE_TTS_DEFAULT_FORMAT="mp3"

# APP_URL: public app URL when deployed.
APP_URL="MY_APP_URL"
